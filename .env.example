# pbOS environment — copy to ~/.config/pbos/.env (chmod 600) or set PBOS_ENV_FILE.
# Phase 1 (foundation + Coach Interview) runs FULLY OFFLINE — none of these are required.
# They only enable best-effort persistence; the deliverables ship without them.

# Supabase (optional persistence mirror — PostgREST + SERVICE key, bypasses RLS)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Authenticity guard strictness (opt-in, for when content skills ship later)
# PBOS_REQUIRE_FACT_TRACE=1   # every authority claim in content must trace to a recorded credential
